{
  "manifest_version": 3,
  "name": "CUDA AI - Active Guard",
  "version": "2.0",
  "description": "Real-time AI fact-checker powered by CUDA AI.",
  "permissions": [
    "sidePanel",
    "activeTab",
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "action": {
    "default_title": "Open Cuda AI"
  }
}
